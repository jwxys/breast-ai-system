# =======================================
# 乳腺 AI 诊断系统 - 环境配置示例
# =======================================

# ---- AI 服务配置 ----
# Kimi API (月暗)
KIMI_API_KEY=sk-your-kimi-key-here

# 通义千问 API (阿里)
TONGYI_API_KEY=sk-your-tongyi-key-here

# ---- 数据库配置 ----
DATABASE_URL=mysql+asyncmy://username:password@localhost:3306/breast_ai

# ---- JWT 认证 ----
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---- 应用配置 ----
APP_NAME=乳腺 AI 辅助诊断系统
APP_VERSION=3.0.0
DEBUG=true

# ---- 文件存储 ----
FILE_STORAGE_PATH=/workspace/breast-ai-system/storage
MAX_FILE_SIZE=10485760  # 10MB

# ---- AI 模型配置 ----
AI_SERVICE_URL=http://localhost:8001
AI_MODEL_NAME=kimi-vision
AI_TIMEOUT=60

# ---- 日志配置 ----
LOG_LEVEL=INFO
LOG_FORMAT=json
